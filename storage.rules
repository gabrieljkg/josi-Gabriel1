rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /gifts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email_verified == true && request.auth.token.email == 'gabrielcalid@gmail.com';
    }
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
